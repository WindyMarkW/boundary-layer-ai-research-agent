[Unit]
Description=Boundary Layer AI Research Agent
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/boundary-layer-ai-research-agent
Environment=NODE_ENV=production
EnvironmentFile=/etc/boundary-layer-ai-research-agent.env
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=5
User=blagent
Group=blagent

[Install]
WantedBy=multi-user.target
